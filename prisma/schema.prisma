generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// -- 1. TAXONOMY (Dynamic Dropdowns & Attributes) --
model TaxonomyTerm {
  id             String          @id @default(uuid())
  category       String // e.g., "VENDOR", "INTERFACE_TYPE", "FEATURE", "SLA", "REGION"
  value          String // e.g., "Cisco Meraki", "WAN"
  label          String
  itemAttributes ItemAttribute[]

  @@unique([category, value])
  @@index([category])
}

// -- 2. UNIFIED CATALOG --
enum ItemType {
  PACKAGE
  HARDWARE
  SOFTWARE
  LICENSE
  MANAGED_SERVICE
  SERVICE_OPTION
  SERVICE_FAMILY
  CONNECTIVITY
}

model CatalogItem {
  id                 String           @id @default(uuid())
  sku                String           @unique
  name               String
  description        String?
  type               ItemType
  configSchema       Json? // JSON Schema for dynamic design option forms (topology, breakout, etc.)
  pricing            Pricing[]
  attributes         ItemAttribute[]
  parentDependencies ItemDependency[] @relation("ParentItem")
  childDependencies  ItemDependency[] @relation("ChildItem")
  primarySites       SolutionSite[]   @relation("PrimarySiteService")
  siteSelections     SiteSelection[]
  collaterals        Collateral[]
  projectItems       ProjectItem[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model ItemAttribute {
  id             String       @id @default(uuid())
  itemId         String
  taxonomyTermId String
  item           CatalogItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  term           TaxonomyTerm @relation(fields: [taxonomyTermId], references: [id], onDelete: Cascade)

  @@unique([itemId, taxonomyTermId])
}

model Collateral {
  id            String       @id @default(uuid())
  catalogItemId String
  title         String
  url           String
  type          String       // e.g., "PDF", "DIAGRAM"
  catalogItem   CatalogItem  @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// -- 3. DEPENDENCY ENGINE (Solves Licensing & Bundles) --
enum DependencyType {
  REQUIRES
  INCLUDES
  MANDATORY_ATTACHMENT
  OPTIONAL_ATTACHMENT
  INCOMPATIBLE
  RECOMMENDS
  IS_A // child IS_A variant of parent SERVICE_FAMILY
}

model ItemDependency {
  id                 String         @id @default(uuid())
  parentId           String
  childId            String
  type               DependencyType
  quantityMultiplier Int            @default(1)
  parentItem         CatalogItem    @relation("ParentItem", fields: [parentId], references: [id], onDelete: Cascade)
  childItem          CatalogItem    @relation("ChildItem", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId, type])
}

// -- 4. PRICING ENGINE (Dimensional & Tiered) --
enum PricingModel {
  FLAT
  TIERED
  PER_UNIT
  USAGE_BASED
  PERCENTAGE
}

model Pricing {
  id             String        @id @default(uuid())
  itemId         String
  pricingModel   PricingModel  @default(FLAT)
  unitOfMeasure  String? // e.g., "Mbps", "Port"
  minQuantity    Int           @default(1)
  maxQuantity    Int?
  costNrc        Decimal       @default(0.00) @db.Decimal(10, 2)
  costMrc        Decimal       @default(0.00) @db.Decimal(10, 2)
  priceNrc       Decimal       @default(0.00) @db.Decimal(10, 2)
  priceMrc       Decimal       @default(0.00) @db.Decimal(10, 2)
  percentageRate Decimal?      @db.Decimal(5, 4)
  termMonths     Int? // Contract term: 12, 36, 60. null = month-to-month
  context        String? // "PRIMARY", "SECONDARY" for role-based pricing
  effectiveDate  DateTime      @default(now())
  expirationDate DateTime?
  item           CatalogItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tiers          PricingTier[]

  @@index([itemId])
  @@index([itemId, termMonths, context])
}

model PricingTier {
  id           String  @id @default(uuid())
  pricingId    String
  startingUnit Int
  endingUnit   Int?
  priceMrc     Decimal @db.Decimal(10, 2)
  costMrc      Decimal @db.Decimal(10, 2)
  pricing      Pricing @relation(fields: [pricingId], references: [id], onDelete: Cascade)

  @@unique([pricingId, startingUnit])
}

// -- 5. PROJECT & SITE QUOTING --
enum ProjectStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ORDERED
  ARCHIVED
}

model Project {
  id           String        @id @default(uuid())
  name         String
  customerName String?
  status          ProjectStatus @default(DRAFT)
  termMonths      Int           @default(1) // Global contract term for the quote
  rawRequirements String?       @db.Text
  sites           SolutionSite[]
  items           ProjectItem[]
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ProjectItem {
  id            String       @id @default(uuid())
  projectId     String
  catalogItemId String
  quantity      Int          @default(1)
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem  @relation(fields: [catalogItemId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([projectId, catalogItemId])
}


model SolutionSite {
  id               String          @id @default(uuid())
  projectId        String
  name             String // e.g., "New York HQ"
  address          String?
  region           String? // REGION taxonomy value for geo-filtering
  primaryServiceId String? // Which service is "primary" at this site
  siteSelections   SiteSelection[]
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  primaryService   CatalogItem?    @relation("PrimarySiteService", fields: [primaryServiceId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model SiteSelection {
  id            String       @id @default(uuid())
  siteId        String
  catalogItemId String
  quantity      Int          @default(1)
  configValues  Json? // User's answers from the configSchema form
  role          String? // "PRIMARY" | "SECONDARY"
  site          SolutionSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem  @relation(fields: [catalogItemId], references: [id])
  createdAt     DateTime     @default(now())

  @@unique([siteId, catalogItemId])
}

// -- 6. USER MANAGEMENT --
enum Role {
  SA
  ADMIN
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  role      Role      @default(SA)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// -- 7. SYSTEM CONFIGURATION --
model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("system_configs")
}
