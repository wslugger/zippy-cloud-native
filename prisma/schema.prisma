generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TaxonomyTerm {
  id                String                    @id @default(uuid())
  category          String
  value             String
  label             String
  lifecycleStatus   LifecycleStatus           @default(SUPPORTED)
  assumptions       String[]
  constraints       String[]
  description       String?
  itemAttributes    ItemAttribute[]
  itemDesignOptions ProjectItemDesignOption[]

  @@unique([category, value])
  @@index([category])
}

model CatalogItem {
  id                     String                         @id @default(uuid())
  sku                    String                         @unique
  name                   String
  type                   ItemType
  primaryPurpose         EquipmentPurpose?
  secondaryPurposes      EquipmentPurpose[]             @default([])
  lifecycleStatus        LifecycleStatus                @default(SUPPORTED)
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  configSchema           Json?
  detailedDescription    String?
  shortDescription       String?
  assumptions            ItemAssumption[]
  attributes             ItemAttribute[]
  collaterals            ItemCollateral[]
  constraints            ItemConstraint[]
  parentDependencies     ItemDependency[]               @relation("ChildItem")
  childDependencies      ItemDependency[]               @relation("ParentItem")
  pricing                Pricing[]
  projectItems           ProjectItem[]
  siteSelections         SiteSelection[]
  primarySites           SolutionSite[]                 @relation("PrimarySiteService")
  designOptions          CatalogItemDesignOption[]
  packageCompositions    PackageCompositionItem[]       @relation("PackageCompositionPackage")
  packageMembers         PackageCompositionItem[]       @relation("PackageCompositionMember")
  packagePolicies        PackageDesignOptionPolicy[]    @relation("PackagePolicyPackage")
  policyTargets          PackageDesignOptionPolicy[]    @relation("PackagePolicyTarget")
  recommendations        ProjectRecommendation[]
  recommendationRunItems ProjectRecommendationRunItem[]
  projectEvents          ProjectEvent[]
  equipmentProfile       EquipmentProfile?
  ingestionSources       EquipmentIngestionSource[]

  @@index([primaryPurpose])
  @@index([secondaryPurposes], type: Gin)
}

model ItemConstraint {
  id          String      @id @default(uuid())
  itemId      String
  description String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  item        CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model ItemAssumption {
  id          String      @id @default(uuid())
  itemId      String
  description String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  item        CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model ItemCollateral {
  id          String      @id @default(uuid())
  itemId      String
  title       String
  documentUrl String
  type        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  catalogItem CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model ItemAttribute {
  id             String       @id @default(uuid())
  itemId         String
  taxonomyTermId String
  item           CatalogItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  term           TaxonomyTerm @relation(fields: [taxonomyTermId], references: [id], onDelete: Cascade)

  @@unique([itemId, taxonomyTermId])
}

model EquipmentProfile {
  catalogItemId       String                @id
  make                String
  model               String
  pricingSku          String?
  family              String?
  vendorDatasheetUrl  String?
  normalizedMakeModel String                @unique
  reviewStatus        EquipmentReviewStatus @default(PUBLISHED)
  lastExtractedAt     DateTime?
  lastExtractedModel  String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  catalogItem         CatalogItem           @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  wanSpec             EquipmentWanSpec?
  lanSpec             EquipmentLanSpec?
  wlanSpec            EquipmentWlanSpec?

  @@index([make, model])
  @@index([reviewStatus, updatedAt])
}

model EquipmentWanSpec {
  catalogItemId    String           @id
  throughputMbps   Int?
  vpnTunnels       Int?
  cellularSupport  Boolean          @default(false)
  formFactor       String?
  interfaces       Json             @default("[]")
  equipmentProfile EquipmentProfile @relation(fields: [catalogItemId], references: [catalogItemId], onDelete: Cascade)
}

model EquipmentLanSpec {
  catalogItemId    String           @id
  portCount        Int?
  portSpeed        String?
  poeBudgetWatts   Int?
  stackable        Boolean          @default(false)
  uplinkPorts      Json             @default("[]")
  equipmentProfile EquipmentProfile @relation(fields: [catalogItemId], references: [catalogItemId], onDelete: Cascade)
}

model EquipmentWlanSpec {
  catalogItemId    String           @id
  wifiStandard     String?
  maxClients       Int?
  indoorOutdoor    String?
  radios           Json             @default("[]")
  equipmentProfile EquipmentProfile @relation(fields: [catalogItemId], references: [catalogItemId], onDelete: Cascade)
}

model EquipmentIngestionJob {
  id           String                      @id @default(uuid())
  status       EquipmentIngestionJobStatus @default(PENDING)
  submittedBy  String?
  errorSummary String?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  startedAt    DateTime?
  completedAt  DateTime?
  sources      EquipmentIngestionSource[]

  @@index([status, createdAt])
}

model EquipmentIngestionSource {
  id                String                         @id @default(uuid())
  jobId             String
  catalogItemId     String?
  url               String
  normalizedUrl     String
  status            EquipmentIngestionSourceStatus @default(PENDING)
  attempts          Int                            @default(0)
  httpStatus        Int?
  contentType       String?
  contentLength     Int?
  extractedText     String?
  extractionPayload Json?
  errorMessage      String?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  processedAt       DateTime?
  job               EquipmentIngestionJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  catalogItem       CatalogItem?                   @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@unique([jobId, normalizedUrl])
  @@index([status, createdAt])
  @@index([catalogItemId])
}

model ItemDependency {
  id                 String         @id @default(uuid())
  parentId           String
  childId            String
  type               DependencyType
  quantityMultiplier Int            @default(1)
  childItem          CatalogItem    @relation("ChildItem", fields: [childId], references: [id], onDelete: Cascade)
  parentItem         CatalogItem    @relation("ParentItem", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId, type])
}

model Pricing {
  id             String        @id @default(uuid())
  itemId         String
  pricingModel   PricingModel  @default(FLAT)
  unitOfMeasure  String?
  minQuantity    Int           @default(1)
  maxQuantity    Int?
  costNrc        Decimal       @default(0.00) @db.Decimal(10, 2)
  costMrc        Decimal       @default(0.00) @db.Decimal(10, 2)
  priceNrc       Decimal       @default(0.00) @db.Decimal(10, 2)
  priceMrc       Decimal       @default(0.00) @db.Decimal(10, 2)
  percentageRate Decimal?      @db.Decimal(5, 4)
  effectiveDate  DateTime      @default(now())
  expirationDate DateTime?
  context        String?
  termMonths     Int?
  currency       String        @default("USD")
  item           CatalogItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tiers          PricingTier[]

  @@unique([itemId, effectiveDate], name: "itemId_effectiveDate")
  @@index([itemId])
  @@index([itemId, termMonths, context])
}

model PricingTier {
  id           String  @id @default(uuid())
  pricingId    String
  startingUnit Int
  endingUnit   Int?
  priceMrc     Decimal @db.Decimal(10, 2)
  costMrc      Decimal @db.Decimal(10, 2)
  pricing      Pricing @relation(fields: [pricingId], references: [id], onDelete: Cascade)

  @@unique([pricingId, startingUnit])
}

model Project {
  id                 String                       @id @default(uuid())
  name               String
  customerName       String?
  status             ProjectStatus                @default(DRAFT)
  workflowStage      ProjectWorkflowStage         @default(PROJECT_CREATED)
  termMonths         Int                          @default(1)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  userId             String?
  rawRequirements    String?
  manualNotes        String?
  user               User?                        @relation(fields: [userId], references: [id])
  items              ProjectItem[]
  sites              SolutionSite[]
  requirementDocs    ProjectRequirementDocument[]
  recommendations    ProjectRecommendation[]
  recommendationRuns ProjectRecommendationRun[]
  events             ProjectEvent[]
  designDocuments    ProjectDesignDocument[]
}

model ProjectItem {
  id                 String                    @id @default(uuid())
  projectId          String
  catalogItemId      String
  quantity           Int                       @default(1)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  configValues       Json?
  designOptionValues Json?
  catalogItem        CatalogItem               @relation(fields: [catalogItemId], references: [id])
  project            Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  designOptions      ProjectItemDesignOption[]

  @@unique([projectId, catalogItemId])
}

model ProjectItemDesignOption {
  id             String       @id @default(uuid())
  projectItemId  String
  taxonomyTermId String
  projectItem    ProjectItem  @relation(fields: [projectItemId], references: [id], onDelete: Cascade)
  term           TaxonomyTerm @relation(fields: [taxonomyTermId], references: [id], onDelete: Cascade)

  @@unique([projectItemId, taxonomyTermId])
}

model SolutionSite {
  id               String          @id @default(uuid())
  projectId        String
  name             String
  address          String?
  region           String?
  primaryServiceId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  siteSelections   SiteSelection[]
  primaryService   CatalogItem?    @relation("PrimarySiteService", fields: [primaryServiceId], references: [id])
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SiteSelection {
  id                 String       @id @default(uuid())
  siteId             String
  catalogItemId      String
  quantity           Int          @default(1)
  configValues       Json?
  designOptionValues Json?
  role               String?
  createdAt          DateTime     @default(now())
  catalogItem        CatalogItem  @relation(fields: [catalogItemId], references: [id])
  site               SolutionSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, catalogItemId])
}

model ProjectDesignDocument {
  id               String               @id @default(uuid())
  projectId        String
  version          Int                  @default(1)
  status           DesignDocumentStatus @default(DRAFT)
  title            String               @default("Design Document")
  executiveSummary String?
  conclusions      String?
  generatorModel   String?
  generationMeta   Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId, status])
}

model User {
  id                 String                     @id @default(uuid())
  email              String                     @unique
  name               String?
  role               Role                       @default(SA)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  projects           Project[]
  recommendationRuns ProjectRecommendationRun[]
  projectEvents      ProjectEvent[]
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("system_configs")
}

model DesignOptionDefinition {
  id              String                      @id @default(uuid())
  key             String                      @unique
  label           String
  lifecycleStatus LifecycleStatus             @default(SUPPORTED)
  description     String?
  constraints     String[]                    @default([])
  assumptions     String[]                    @default([])
  valueType       DesignOptionValueType
  isActive        Boolean                     @default(true)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  values          DesignOptionValue[]
  itemOptions     CatalogItemDesignOption[]
  policies        PackageDesignOptionPolicy[]
}

model DesignOptionValue {
  id               String                           @id @default(uuid())
  designOptionId   String
  value            String
  label            String
  description      String?
  constraints      String[]                         @default([])
  assumptions      String[]                         @default([])
  sortOrder        Int                              @default(0)
  isActive         Boolean                          @default(true)
  createdAt        DateTime                         @default(now())
  updatedAt        DateTime                         @updatedAt
  designOption     DesignOptionDefinition           @relation(fields: [designOptionId], references: [id], onDelete: Cascade)
  itemOptions      CatalogItemDesignOption[]        @relation("CatalogItemDesignOptionDefault")
  itemOptionValues CatalogItemDesignOptionValue[]
  policyValues     PackageDesignOptionPolicyValue[]

  @@unique([designOptionId, value])
  @@index([designOptionId, sortOrder])
}

model CatalogItemDesignOption {
  id             String                         @id @default(uuid())
  catalogItemId  String
  designOptionId String
  isRequired     Boolean                        @default(false)
  allowMulti     Boolean                        @default(false)
  defaultValueId String?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  catalogItem    CatalogItem                    @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  designOption   DesignOptionDefinition         @relation(fields: [designOptionId], references: [id], onDelete: Cascade)
  defaultValue   DesignOptionValue?             @relation("CatalogItemDesignOptionDefault", fields: [defaultValueId], references: [id], onDelete: SetNull)
  allowedValues  CatalogItemDesignOptionValue[]

  @@unique([catalogItemId, designOptionId])
  @@index([catalogItemId])
  @@index([designOptionId])
}

model CatalogItemDesignOptionValue {
  id                  String                  @id @default(uuid())
  itemDesignOptionId  String
  designOptionValueId String
  itemDesignOption    CatalogItemDesignOption @relation(fields: [itemDesignOptionId], references: [id], onDelete: Cascade)
  designOptionValue   DesignOptionValue       @relation(fields: [designOptionValueId], references: [id], onDelete: Cascade)

  @@unique([itemDesignOptionId, designOptionValueId])
  @@index([itemDesignOptionId])
  @@index([designOptionValueId])
}

model PackageCompositionItem {
  id            String                 @id @default(uuid())
  packageId     String
  catalogItemId String
  role          PackageCompositionRole
  minQty        Int                    @default(1)
  maxQty        Int?
  defaultQty    Int                    @default(1)
  isSelectable  Boolean                @default(true)
  displayOrder  Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  package       CatalogItem            @relation("PackageCompositionPackage", fields: [packageId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem            @relation("PackageCompositionMember", fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([packageId, catalogItemId])
  @@index([packageId, role])
}

model PackageDesignOptionPolicy {
  id                  String                           @id @default(uuid())
  packageId           String
  targetCatalogItemId String
  designOptionId      String
  operator            PackagePolicyOperator
  scope               PackagePolicyScope               @default(PROJECT)
  active              Boolean                          @default(true)
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt
  package             CatalogItem                      @relation("PackagePolicyPackage", fields: [packageId], references: [id], onDelete: Cascade)
  targetCatalogItem   CatalogItem                      @relation("PackagePolicyTarget", fields: [targetCatalogItemId], references: [id], onDelete: Cascade)
  designOption        DesignOptionDefinition           @relation(fields: [designOptionId], references: [id], onDelete: Cascade)
  values              PackageDesignOptionPolicyValue[]

  @@unique([packageId, targetCatalogItemId, designOptionId, operator])
  @@index([packageId, active])
  @@index([targetCatalogItemId, designOptionId])
}

model PackageDesignOptionPolicyValue {
  id                  String                    @id @default(uuid())
  policyId            String
  designOptionValueId String
  policy              PackageDesignOptionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  designOptionValue   DesignOptionValue         @relation(fields: [designOptionValueId], references: [id], onDelete: Cascade)

  @@unique([policyId, designOptionValueId])
  @@index([policyId])
}

model ProjectRequirementDocument {
  id            String                    @id @default(uuid())
  projectId     String
  fileName      String
  mimeType      String
  gcsUri        String
  extractedText String?
  status        RequirementDocumentStatus @default(UPLOADED)
  errorMessage  String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  project       Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

model ProjectRecommendation {
  id                  String              @id @default(uuid())
  projectId           String
  catalogItemId       String
  reason              String
  score               Decimal             @default(0) @db.Decimal(6, 3)
  sourceModel         String
  state               RecommendationState @default(PENDING)
  requiredIncluded    String[]
  optionalRecommended String[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  project             Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  catalogItem         CatalogItem         @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([projectId, catalogItemId])
  @@index([projectId, state])
}

model ProjectRecommendationRun {
  id                  String                         @id @default(uuid())
  projectId           String
  userId              String?
  sourceModel         String
  recommendationCount Int                            @default(0)
  createdAt           DateTime                       @default(now())
  project             Project                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User?                          @relation(fields: [userId], references: [id], onDelete: SetNull)
  items               ProjectRecommendationRunItem[]

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
}

model ProjectRecommendationRunItem {
  id                     String                   @id @default(uuid())
  runId                  String
  catalogItemId          String
  rank                   Int
  score                  Decimal                  @default(0) @db.Decimal(6, 3)
  certaintyPercent       Int                      @default(0)
  reason                 String
  shortReason            String?
  requiredIncluded       String[]
  optionalRecommended    String[]
  matchedCharacteristics String[]
  coverageAreas          String[]
  riskFactors            String[]
  createdAt              DateTime                 @default(now())
  run                    ProjectRecommendationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  catalogItem            CatalogItem              @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([runId, rank])
  @@index([catalogItemId, createdAt])
}

model ProjectEvent {
  id            String                @id @default(uuid())
  projectId     String
  userId        String?
  eventType     ProjectEventType
  workflowStage ProjectWorkflowStage?
  catalogItemId String?
  collateralId  String?
  metadata      Json?
  createdAt     DateTime              @default(now())
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  catalogItem   CatalogItem?          @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@index([catalogItemId, createdAt])
  @@index([collateralId, createdAt])
}

enum ItemType {
  PACKAGE
  HARDWARE
  MANAGED_SERVICE
  SERVICE_OPTION
  CONNECTIVITY
}

enum DependencyType {
  REQUIRES
  INCLUDES
  MANDATORY_ATTACHMENT
  OPTIONAL_ATTACHMENT
  INCOMPATIBLE
  RECOMMENDS
}

enum PricingModel {
  FLAT
  TIERED
  PER_UNIT
  USAGE_BASED
  PERCENTAGE
}

enum DesignOptionValueType {
  STRING
  NUMBER
  BOOLEAN
}

enum LifecycleStatus {
  SUPPORTED
  IN_DEVELOPMENT
  APPROVAL_REQUIRED
  DEPRECATED
  END_OF_SALE
  END_OF_SUPPORT
  NOT_AVAILABLE
}

enum ProjectStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ORDERED
  ARCHIVED
}

enum ProjectWorkflowStage {
  PROJECT_CREATED
  REQUIREMENTS_CAPTURED
  RECOMMENDATIONS_READY
  SERVICE_SELECTED
}

enum Role {
  SA
  ADMIN
}

enum PackageCompositionRole {
  REQUIRED
  OPTIONAL
  AUTO_INCLUDED
}

enum PackagePolicyOperator {
  FORCE
  FORBID
  ALLOW_ONLY
  REQUIRE_ONE_OF
}

enum PackagePolicyScope {
  PROJECT
  SITE
}

enum RequirementDocumentStatus {
  UPLOADED
  PARSED
  FAILED
}

enum RecommendationState {
  PENDING
  ADOPTED
  DISMISSED
}

enum ProjectEventType {
  PROJECT_CREATED
  REQUIREMENT_DOC_UPLOADED
  NOTES_ENTERED
  RECOMMENDATIONS_GENERATED
  RECOMMENDATION_ADOPTED
  SERVICE_MANUALLY_ADDED
  SERVICE_REMOVED
  COLLATERAL_CLICKED
}

enum DesignDocumentStatus {
  DRAFT
  PUBLISHED
}

enum EquipmentPurpose {
  WAN
  LAN
  WLAN
}

enum EquipmentReviewStatus {
  DRAFT
  PUBLISHED
  REJECTED
}

enum EquipmentIngestionJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum EquipmentIngestionSourceStatus {
  PENDING
  PROCESSING
  UPSERTED
  SKIPPED
  FAILED
}
